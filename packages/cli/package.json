{
    "name": "termviz",
    "version": "0.1.0",
    "description": "termviz CLI — render diagrams and UI previews inline in any terminal",
    "type": "module",
    "bin": {
        "termviz": "./dist/index.js"
    },
    "main": "./dist/index.js",
    "exports": {
        ".": {
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "clean": "rimraf dist"
    },
    "dependencies": {
        "@termviz/core": "*",
        "commander": "^12.0.0",
        "chalk": "^5.3.0",
        "ora": "^8.0.1",
        "sharp": "^0.33.2",
        "sixel": "^0.16.0"
    },
    "devDependencies": {
        "rimraf": "^5.0.5",
        "vitest": "^1.2.2"
    }
}